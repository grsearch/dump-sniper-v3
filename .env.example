# ============================================================================
# Dump Sniper V3 - Environment Variables
# ============================================================================
# v3 关键变化：去掉 Jupiter，直调 Pump.fun AMM (PumpSwap) via 官方 SDK
# 延迟从 v2 的 ~250ms (Jupiter HTTP) 降到 ~80ms (RPC + 本地构造)
# ============================================================================

# ============ Mode ============
# DRY_RUN=true 时不实际下单，仅记录信号和模拟执行
# 强烈建议先跑 24-48h DRY_RUN 验证策略胜率再切 LIVE
DRY_RUN=true

# ============ Strategy ============
# 触发条件
MIN_SELL_SOL=10.0
MIN_PRICE_IMPACT_PCT=10.0

# 仓位（先从小金额开始！v1 已经因为 bug 亏过钱）
POSITION_SIZE_SOL=0.1

# 止盈：双确认机制（v2 新增）
# 连续 TP_CONFIRM_COUNT 次满足 +TAKE_PROFIT_PCT% 才真正卖
# 防止单次价格污染触发假止盈
TAKE_PROFIT_PCT=8.0
TP_CONFIRM_COUNT=2
TP_CONFIRM_MIN_GAP_MS=300

# 紧急止损（v2 新增）：跌幅 <= 此值立即出场
# 防止 v1 那种 -97% 灾难性亏损
# 设为 0 则禁用（恢复"硬扛到 maxHoldMs"行为）
EMERGENCY_STOP_LOSS_PCT=-15.0

# 最大持仓时间（毫秒）
MAX_HOLD_MS=15000

# 滑点（bps，10000 = 100%）
# Pump SDK 接受 percent (1500 bps = 15%)，注意单位
BUY_SLIPPAGE_BPS=1500
SELL_SLIPPAGE_BPS=2000

# 风控
COOLDOWN_MS_PER_TOKEN=60000
MAX_CONCURRENT_POSITIONS=3

# ============ Price Anomaly Filter ============
# 单 tick 价格变化超过 ±maxJumpRatio 视为可疑，需要双确认
# 1.5 = ±50% 跳变（实际 +50% 或 -33% 以上）
PRICE_MAX_JUMP_RATIO=1.5
PRICE_CONFIRM_WINDOW_MS=3000
PRICE_CONFIRM_MIN_SAMPLES=2

# ============ Helius ============
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Staked sendTransaction endpoint (Business plan 提供)
HELIUS_STAKED_RPC_URL=https://staked.helius-rpc.com?api-key=YOUR_KEY

# 可选但强烈推荐：Helius Sender 加速 tx 提交（FRA: https://sender.helius-rpc.com/fast）
# 留空则用 staked RPC
HELIUS_SENDER_ENDPOINT=

# LaserStream gRPC (用于实时交易订阅)
# ⚠️ 选择离服务器最近的端点：
#   法兰克福: https://laserstream-mainnet-fra.helius-rpc.com  (推荐欧洲服务器)
#   阿姆斯特丹: https://laserstream-mainnet-ams.helius-rpc.com
#   东京: https://laserstream-mainnet-tyo.helius-rpc.com
#   新加坡: https://laserstream-mainnet-sgp.helius-rpc.com
#   纽约: https://laserstream-mainnet-ewr.helius-rpc.com
#   匹兹堡: https://laserstream-mainnet-pitt.helius-rpc.com
#   盐湖城: https://laserstream-mainnet-slc.helius-rpc.com
HELIUS_LASERSTREAM_ENDPOINT=https://laserstream-mainnet-fra.helius-rpc.com
HELIUS_LASERSTREAM_TOKEN=your_laserstream_token_here

# ============ Pump AMM (v3: 直调，无第三方聚合器) ============
# Compute unit limit — 必须够覆盖 buy/sell 主指令 + 内部 fee_program CPI
# 实测 buy/sell 大约消耗 80k-200k CU；300k 是安全余量
COMPUTE_UNIT_LIMIT=300000

# ============ Priority fees (v3.1+: BUY 高 fee 抢入，SELL 低 fee 节省成本) ============
# 实测竞争者钱包：BUY 0.012-0.045 SOL，SELL <0.0001-0.003 SOL
#
# 动态模式（推荐）：用 Helius getPriorityFeeEstimate 实时查询 mempool 拥堵
# 砸盘事件中整网 fee 飙升，自动跟上竞争者；非事件时段省 fee
PRIORITY_FEE_DYNAMIC=true

# 动态模式下 BUY/SELL 用哪个 percentile 级别
# 可选: min, low, medium (50%), high (75%), veryHigh (95%), unsafeMax
# BUY 用 veryHigh（砸盘抢入，整网最高 5% 的 fee），SELL 用 medium 即可
BUY_PRIORITY_LEVEL=veryHigh
SELL_PRIORITY_LEVEL=medium

# 动态模式的下限（防止 RPC 返回 0 或过低，导致进不了 leader）
BUY_MIN_PRIORITY_FEE_LAMPORTS=10000000   # 0.01 SOL
SELL_MIN_PRIORITY_FEE_LAMPORTS=100000    # 0.0001 SOL

# 动态模式的上限（防止 RPC 异常返回天文数字烧钱）
BUY_CAP_PRIORITY_FEE_LAMPORTS=50000000   # 0.05 SOL
SELL_CAP_PRIORITY_FEE_LAMPORTS=2000000   # 0.002 SOL

# 静态模式 fallback（PRIORITY_FEE_DYNAMIC=false 或 RPC 失败时使用）
BUY_MAX_PRIORITY_FEE_LAMPORTS=20000000   # 0.02 SOL
SELL_MAX_PRIORITY_FEE_LAMPORTS=500000    # 0.0005 SOL

# 旧的统一字段（向后兼容，新部署可忽略）
MAX_PRIORITY_FEE_LAMPORTS=5000000

# ============ Birdeye ============
BIRDEYE_API_KEY=your_birdeye_key_here

# ============ Wallet ============
# 交易钱包私钥 (base58 编码)。仅 LIVE 模式需要
WALLET_PRIVATE_KEY_BS58=

# ============ Server ============
DASHBOARD_PORT=3001
# 监听网卡：0.0.0.0 = 全部，127.0.0.1 = 仅本地（用 SSH tunnel 时推荐）
BIND_HOST=0.0.0.0
# 可选：webhook 共享密钥
WEBHOOK_SECRET=
# 可选：dashboard 访问令牌（建议 LIVE 时启用）
# 生成: openssl rand -hex 32
DASHBOARD_TOKEN=

# ============ Misc ============
# 启动时是否后台自动补缺失的 pool 信息
AUTO_FILL_POOLS_ON_START=true
