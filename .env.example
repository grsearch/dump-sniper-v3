# ============================================================================
# Dump Sniper V3 - Environment Variables
# ============================================================================
# v3 关键变化：去掉 Jupiter，直调 Pump.fun AMM (PumpSwap) via 官方 SDK
# 延迟从 v2 的 ~250ms (Jupiter HTTP) 降到 ~80ms (RPC + 本地构造)
# ============================================================================

# ============ Mode ============
# DRY_RUN=true 时不实际下单，仅记录信号和模拟执行
# 强烈建议先跑 24-48h DRY_RUN 验证策略胜率再切 LIVE
DRY_RUN=true

# ============ Strategy ============
# 触发条件 (v3.10: 加 max impact + 池子流动性下限，过滤伪砸盘和流动性死亡的池子)
#
# 实盘数据：之前 10/10 双 AND 抓到的多是边缘案例
#   - 大池子 10 SOL 卖单 → impact 5-9% → 没反弹空间
#   - 小池子 10 SOL 卖单 → impact 30%+ → 有反弹但流动性危险，进出滑点大
#   - 真正赚钱的：sell ≥ 15 SOL + impact 12-30% + 池子流动性 ≥ 30 SOL
#
MIN_SELL_SOL=15.0          # 决心卖单 (10 SOL 太小)
MIN_PRICE_IMPACT_PCT=12.0  # 反弹下限 (10% 反弹空间太小)
MAX_PRICE_IMPACT_PCT=30.0  # 反弹上限 (>30% 通常池子已死)
MIN_POOL_QUOTE_SOL=30.0    # 池子最少 SOL 流动性 (微盘容易被卡)

# 仓位（先从小金额开始！v1 已经因为 bug 亏过钱）
POSITION_SIZE_SOL=0.1

# 止盈：双确认机制（v2 新增）
# 连续 TP_CONFIRM_COUNT 次满足 +TAKE_PROFIT_PCT% 才真正卖
# 防止单次价格污染触发假止盈
TAKE_PROFIT_PCT=8.0
TP_CONFIRM_COUNT=2
TP_CONFIRM_MIN_GAP_MS=300

# 紧急止损（v2 新增）：跌幅 <= 此值立即出场
# 防止 v1 那种 -97% 灾难性亏损
# 设为 0 则禁用（恢复"硬扛到 maxHoldMs"行为）
EMERGENCY_STOP_LOSS_PCT=-15.0

# 最大持仓时间（毫秒）
MAX_HOLD_MS=15000

# v3.4: 持仓期间主动池子轮询间隔（毫秒）
# 修复 TIMEOUT 主导问题：微盘币 15s 内可能没有外部 swap 触发 PriceTracker，
# 导致价格永远是 entryPrice，永远不止盈也不止损，全部走到 TIMEOUT。
# 持仓期间每 X ms 主动拉每个 token 的 pool state 算实时价。
# 500ms 默认值：15s 持仓 = 30 次轮询 = 30 次 RPC，对 Helius Business 配额无压力。
# 想更激进降到 250ms（60 次/持仓）；想省配额升到 1000ms。
POOL_POLL_INTERVAL_MS=500

# v3.14 滚动式后台 pool state 刷新
# 每个 token 被刷新一次的周期。70 token + 5s = 平均 14 RPS（无爆发）
# 实测 swapSolanaState 内部可能拉多个账户，实际 RPS 可达 2-4 倍
# Helius Business 限 50 RPS，70 token × 4 acct / 5s = 56 RPS → 调到 5s 仍危险
# 推荐：监控 ≤ 50 token 用 3000ms；50-100 token 用 5000ms；100+ token 用 8000ms
POOL_STATE_REFRESH_MS=5000

# v3.14 滚动刷新的 tick 间隔
# 把 N 个 token 均匀分摊到这个 tick 频率上，避免瞬时 RPS 爆发
# 默认 200ms = 每秒 5 次小批量；每批刷 N × tick/refresh 个 token
# 不需要调，保持默认
POOL_STATE_TICK_MS=200

# 滑点（bps，10000 = 100%）
# Pump SDK 接受 percent (1500 bps = 15%)，注意单位
BUY_SLIPPAGE_BPS=1500
SELL_SLIPPAGE_BPS=2000

# 风控
COOLDOWN_MS_PER_TOKEN=60000
MAX_CONCURRENT_POSITIONS=3

# ============ Price Anomaly Filter ============
# 单 tick 价格变化超过 ±maxJumpRatio 视为可疑，需要双确认
# 1.5 = ±50% 跳变（实际 +50% 或 -33% 以上）
PRICE_MAX_JUMP_RATIO=1.5
PRICE_CONFIRM_WINDOW_MS=3000
PRICE_CONFIRM_MIN_SAMPLES=2

# ============ Helius ============
# v3.15 RPC 通道分流（关键！避免一个 endpoint 被打爆）
#   - HELIUS_RPC_URL：普通公共节点，用于 PoolStateCache 后台刷新 + 查询类调用
#     【建议用标准共享端点】https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
#     ⚠️ 不要用专属/Secure 端点（如 donetta-1niumo-fast-...），专属节点限流严格，
#        70 个 token 滚动刷新会打爆它（实测每分钟数百 429）
#   - HELIUS_STAKED_RPC_URL：staked 端点，**仅用于 sendTransaction**
#     Business 计划的主 URL 就是 staked，可填同一个 URL
#   - HELIUS_SENDER_ENDPOINT：Helius Sender 服务（带 Jito 通道，强烈推荐）
HELIUS_API_KEY=your_helius_api_key_here

# 普通 RPC（用于 PoolStateCache 后台刷新 + 查询）
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Staked sendTransaction endpoint — 仅用于 sendTransaction，**不参与 PoolStateCache**
# Business 计划主 URL 自动就是 staked，跟 HELIUS_RPC_URL 填一样即可
HELIUS_STAKED_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# v3.13 / v3.16 Helius Sender — 强烈推荐启用（仅 BUY 走，SELL 自动绕过）
# Sender = 同时投递到 validator (SWQoS) + Jito 拍卖，双通道命中率更高
#
# ⚠️ Endpoint 选择（实测踩过的坑）：
#   - 优先用全局域名 https://sender.helius-rpc.com/fast（走 Cloudflare，最稳）
#   - 区域前缀 fra-sender / slc-sender 等 是裸 IP (64.130.x.x)
#     某些云服务器（如部分阿里云、Tencent Cloud）会拒绝这些裸 IP（Connection refused）
#   - 如果你服务器能直连裸 IP，区域端点延迟更低 5-10ms（值得测试）
#
# 7 个区域 endpoints:
#   法兰克福: http://fra-sender.helius-rpc.com/fast
#   阿姆斯特丹: http://ams-sender.helius-rpc.com/fast
#   东京: http://tyo-sender.helius-rpc.com/fast
#   新加坡: http://sg-sender.helius-rpc.com/fast
#   伦敦: http://lon-sender.helius-rpc.com/fast
#   纽约: http://ewr-sender.helius-rpc.com/fast
#   盐湖城: http://slc-sender.helius-rpc.com/fast
#
# 留空 → 只用 staked RPC（BUY 错过 Jito 通道，速度差不多但少一个通道）
# v3.16: SELL 不走 Sender（SELL tx 不带 tip 会被 Sender 拒收 → 浪费 500-700ms）
HELIUS_SENDER_ENDPOINT=https://sender.helius-rpc.com/fast

# v3.13 / v3.16 Jito tip (lamports) — BUY 才会附加这个 tip 转账
# ⚠️ Helius Sender 官方要求最低 0.0002 SOL = 200_000 lamports
# 推荐 1_000_000 lamports (0.001 SOL) = 远超门槛 + 适度激进
# 砸盘抢入特别激烈时可推到 2_000_000 - 5_000_000 (0.002-0.005 SOL)
# 提示：tip 直接转账给 Helius 指定的 10 个钱包之一（不计入 priority fee 排序，不影响 μL/CU）
JITO_TIP_LAMPORTS=1000000

# LaserStream gRPC (用于实时交易订阅)
# ⚠️ 选择离服务器最近的端点：
#   法兰克福: https://laserstream-mainnet-fra.helius-rpc.com  (推荐欧洲服务器)
#   阿姆斯特丹: https://laserstream-mainnet-ams.helius-rpc.com
#   东京: https://laserstream-mainnet-tyo.helius-rpc.com
#   新加坡: https://laserstream-mainnet-sgp.helius-rpc.com
#   纽约: https://laserstream-mainnet-ewr.helius-rpc.com
#   匹兹堡: https://laserstream-mainnet-pitt.helius-rpc.com
#   盐湖城: https://laserstream-mainnet-slc.helius-rpc.com
HELIUS_LASERSTREAM_ENDPOINT=https://laserstream-mainnet-fra.helius-rpc.com
HELIUS_LASERSTREAM_TOKEN=your_laserstream_token_here

# ============ Pump AMM (v3: 直调，无第三方聚合器) ============
# Compute unit limit — 必须够覆盖 buy/sell 主指令 + 内部 fee_program CPI
#
# v3.4 设 150K：实测成功 swap 消耗 135K-146K CU，余量仅 4K-14K
# v3.9 改 200K：HERMES 等带 fee_program CPI 的 swap 会超 150K → ProgramFailedToComplete
# 200K 给足 ~30% 余量，同时 fee 单价仍比默认 300K 高 50%（300K/200K = 1.5x）
#
# ⚠️ 关键性能因素：Solana leader 排序看的是 microLamports/CU 单价，不是总 priority fee
# CU 太小 → 偶尔爆单（程序仍当成成功，token 卡钱包）
# CU 太大 → fee 单价变低，输给竞争者
# 200K 是数据驱动的最优值
COMPUTE_UNIT_LIMIT=200000

# ============ Priority fees (v3.1+: BUY 高 fee 抢入，SELL 低 fee 节省成本) ============
# 实测竞争者钱包：BUY 0.012-0.045 SOL，SELL <0.0001-0.003 SOL
#
# 动态模式（推荐）：用 Helius getPriorityFeeEstimate 实时查询 mempool 拥堵
# 砸盘事件中整网 fee 飙升，自动跟上竞争者；非事件时段省 fee
PRIORITY_FEE_DYNAMIC=true

# 动态模式下 BUY/SELL 用哪个 percentile 级别
# 可选: min, low, medium (50%), high (75%), veryHigh (95%), unsafeMax
# BUY 用 veryHigh（砸盘抢入，整网最高 5% 的 fee），SELL 用 medium 即可
BUY_PRIORITY_LEVEL=veryHigh
SELL_PRIORITY_LEVEL=medium

# 动态模式的下限（防止 RPC 返回 0 或过低，导致进不了 leader）
BUY_MIN_PRIORITY_FEE_LAMPORTS=10000000   # 0.01 SOL
SELL_MIN_PRIORITY_FEE_LAMPORTS=100000    # 0.0001 SOL

# 动态模式的上限（防止 RPC 异常返回天文数字烧钱）
# v3.11 ⚠️ 关键修复：之前 0.05 SOL cap 把单价卡死在 250K μL/CU
#         实测 FYX5 用 40M μL/CU、3fZftz6m 用 72M μL/CU
#         leader 排序看的就是 μL/CU，cap 太低导致同 slot 内排到后面
#         改 0.2 SOL = 真正能让 dynamic veryHigh 生效（μL/CU 上限到 1M）
#         砸盘事件下整网拥堵时这才是合理上限
BUY_CAP_PRIORITY_FEE_LAMPORTS=200000000  # 0.2 SOL
SELL_CAP_PRIORITY_FEE_LAMPORTS=2000000   # 0.002 SOL

# 静态模式 fallback（PRIORITY_FEE_DYNAMIC=false 或 RPC 失败时使用）
BUY_MAX_PRIORITY_FEE_LAMPORTS=20000000   # 0.02 SOL
SELL_MAX_PRIORITY_FEE_LAMPORTS=500000    # 0.0005 SOL

# 旧的统一字段（向后兼容，新部署可忽略）
MAX_PRIORITY_FEE_LAMPORTS=5000000

# ============ Birdeye ============
BIRDEYE_API_KEY=your_birdeye_key_here

# ============ Wallet ============
# 交易钱包私钥 (base58 编码)。仅 LIVE 模式需要
WALLET_PRIVATE_KEY_BS58=

# ============ Server ============
DASHBOARD_PORT=3001
# 监听网卡：0.0.0.0 = 全部，127.0.0.1 = 仅本地（用 SSH tunnel 时推荐）
BIND_HOST=0.0.0.0
# 可选：webhook 共享密钥
WEBHOOK_SECRET=
# 可选：dashboard 访问令牌（建议 LIVE 时启用）
# 生成: openssl rand -hex 32
DASHBOARD_TOKEN=

# ============ Misc ============
# 启动时是否后台自动补缺失的 pool 信息
AUTO_FILL_POOLS_ON_START=true
