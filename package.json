{
  "name": "dump-sniper",
  "version": "3.9.0",
  "description": "Solana Pump.fun dump-rebound sniper. Detects large sell orders with high price impact, executes counter-trade buys via direct Pump AMM SDK, exits on rebound or timeout.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --trace-warnings src/index.js",
    "health": "node scripts/health.js",
    "health:json": "node scripts/health.js --json",
    "fill-pools": "node scripts/fill-pools.js",
    "latency": "node scripts/latency-analyze.js",
    "dissect": "node scripts/latency-dissect.js",
    "stuck": "node scripts/stuck.js"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@pump-fun/pump-swap-sdk": "^1.14.0",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.3",
    "@triton-one/yellowstone-grpc": "^1.3.0",
    "axios": "^1.7.7",
    "better-sqlite3": "^11.3.0",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
